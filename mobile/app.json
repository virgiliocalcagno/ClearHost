{
  "expo": {
    "name": "ClearHost Staff",
    "slug": "clearhost-staff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#F5F5F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clearhost.staff",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "ClearHost necesita acceso a la cámara para tomar fotos de evidencia de limpieza.",
        "NSPhotoLibraryUsageDescription": "ClearHost necesita acceso a la galería para seleccionar fotos de evidencia."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F5F7"
      },
      "package": "com.clearhost.staff",
      "googleServicesFile": "./google-services.json",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ]
    ]
  }
}
